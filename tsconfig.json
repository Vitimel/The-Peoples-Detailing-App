{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "target": "ES2020",
    "noEmit": true,
    "strict": false
  },
  "include": ["src", "tests", "vite.config.js", "vitest.config.js", "playwright.config.js"]
}
